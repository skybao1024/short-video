# Environment configuration
ENV=development

# Basic configuration
PROJECT_NAME=FastAPI Template
API_V1_STR=/api/v1
API_PORT=8001

# Database configuration
# Use the same regional PostgreSQL database as the crawler service.
# FastAPI uses async SQLAlchemy, so the driver must be asyncpg.
DATABASE_URL=postgresql+asyncpg://crawler_api:replace-with-password@127.0.0.1:5432/crawler

# Crawler notices API configuration
DATA_REGION=EU
API_AUTH_MODE=aksk
API_KEYS_JSON={"partner-eu-1":{"secret":"replace-with-secret","enabled":true}}
API_SIGNATURE_TTL_SECONDS=300

# Redis configuration
# Use the same regional Redis service as the crawler service.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Celery configuration (auto-generated, no manual configuration needed)
# CELERY_BROKER_URL and CELERY_RESULT_BACKEND will be auto-generated based on Redis configuration

# HTTP proxy configuration - recommend closing in production environment
USE_HTTP_PROXY=false
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890

# Email configuration
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM_ADDRESS=your_email@gmail.com
MAIL_FROM_NAME="FastAPI Template"
MAIL_ENCRYPTION=tls

# Brevo configuration (optional, if using Brevo service)
BREVO_API_KEY=your_brevo_api_key
BREVO_EMAIL_FROM=your_email@domain.com
BREVO_EMAIL_FROM_NAME="FastAPI Template"

# Admin email
ADMIN_EMAIL=admin@yourdomain.com

# JWT configuration
SECRET_KEY=your_very_long_secret_key_here_please_change_this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS S3 configuration
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_REGION=us-east-1
AWS_BUCKET_NAME=v-gen-dev
AWS_ENDPOINT=http://minio:9000
AWS_ENDPOINT_PUBLIC=http://localhost:9002

# Video generation provider configuration
GEMINI_API_KEY=
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
RUNWAYML_API_SECRET=
RUNWAY_API_BASE_URL=https://api.dev.runwayml.com/v1
RUNWAY_API_VERSION=2024-11-06
VIDEO_PROVIDER_TIMEOUT_SECONDS=120
VIDEO_PROVIDER_SUBMIT_MAX_RETRIES=2
VIDEO_PROVIDER_SUBMIT_RETRY_BACKOFF_SECONDS=5
VIDEO_PROVIDER_SUBMIT_RETRY_MAX_BACKOFF_SECONDS=30
VIDEO_PROVIDER_POLL_INTERVAL_SECONDS=10
VIDEO_PROVIDER_MAX_POLL_SECONDS=7200
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_STORYBOARD_MODEL=gpt-5.5
OPENAI_STORYBOARD_TIMEOUT_SECONDS=45
OPENAI_IMAGE_ANALYSIS_MODEL=gpt-5.5
OPENAI_IMAGE_ANALYSIS_DETAIL=original
OPENAI_IMAGE_ANALYSIS_TIMEOUT_SECONDS=60

# MinIO configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_PORT=9002
MINIO_CONSOLE_PORT=9001

# Google OAuth configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8001/api/v1/auth/google/callback

# Frontend URL configuration
FRONTEND_URL=http://localhost:3000

# Verification code configuration
VERIFICATION_CODE_LENGTH=6
VERIFICATION_CODE_EXPIRE_SECONDS=300
VERIFICATION_CODE_COOLDOWN_SECONDS=60

# Password reset configuration
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

{
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Bash(python:*)",
      "Bash(source:*)",
      "Bash(alembic:*)",
      "Bash(docker-compose:*)",
      "Bash(docker:*)",
      "Bash(black:*)",
      "Bash(isort:*)",
      "Bash(flake8:*)",
      "Bash(git:*)",
      "Bash(celery:*)",
      "Bash(pytest:*)",
      "Bash(pip:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(sed:*)",
      "Bash(grep:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Read",
      "WebFetch",
      "WebSearch"
    ],
    "ask": [
      "Bash(rm:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Read(*.env)",
      "Read(*.env.local)",
      "Read(*.env.production)",
      "Read(*/.env)",
      "Read(*/.env.local)",
      "Read(*/.env.production)",
      "Bash(cat *.env*)",
      "Bash(cat .env*)",
      "Bash(grep * *.env*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": []
}
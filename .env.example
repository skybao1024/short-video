# Project configuration
PROJECT_NAME=v-gen
ENV=development

# Docker image configuration
# Override these when Docker Hub is unavailable in your network.
PYTHON_IMAGE=python:3.14.5-slim
NODE_IMAGE=node:20-alpine
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
MINIO_IMAGE=minio/minio:latest
MINIO_CLIENT_IMAGE=minio/mc:latest

# Frontend configuration
FRONTEND_DEV_PORT=3000
FRONTEND_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:8001/api

# Backend API configuration
API_V1_STR=/api/v1
API_PORT=8001

# PostgreSQL configuration
POSTGRES_USER=v_gen
POSTGRES_PASSWORD=v_gen_password
POSTGRES_DB=v_gen
POSTGRES_EXTERNAL_PORT=5433
DATABASE_URL=postgresql+asyncpg://v_gen:v_gen_password@postgres:5432/v_gen

# Redis configuration
REDIS_HOST=redis
REDIS_PORT=6479
REDIS_PASSWORD=v_gen_redis_password
REDIS_EXTERNAL_PORT=6479

# HTTP proxy configuration
USE_HTTP_PROXY=false
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890

# JWT configuration
# Generate a production value with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=local-development-secret-key-change-before-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email configuration
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="v-gen"
MAIL_ENCRYPTION=tls

# Brevo configuration
BREVO_API_KEY=
BREVO_EMAIL_FROM=noreply@example.com
BREVO_EMAIL_FROM_NAME="v-gen"

# Admin email
ADMIN_EMAIL=admin@example.com

# AWS S3 configuration
# Local development uses MinIO through the S3-compatible boto3 client.
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_REGION=us-east-1
AWS_BUCKET_NAME=v-gen-dev
AWS_ENDPOINT=http://minio:9000
AWS_ENDPOINT_PUBLIC=http://localhost:9002

# Video generation provider configuration
GEMINI_API_KEY=
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
RUNWAYML_API_SECRET=
RUNWAY_API_BASE_URL=https://api.dev.runwayml.com/v1
RUNWAY_API_VERSION=2024-11-06
VIDEO_PROVIDER_TIMEOUT_SECONDS=120
VIDEO_PROVIDER_SUBMIT_MAX_RETRIES=2
VIDEO_PROVIDER_SUBMIT_RETRY_BACKOFF_SECONDS=5
VIDEO_PROVIDER_SUBMIT_RETRY_MAX_BACKOFF_SECONDS=30
VIDEO_PROVIDER_POLL_INTERVAL_SECONDS=10
VIDEO_PROVIDER_MAX_POLL_SECONDS=7200
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_STORYBOARD_MODEL=gpt-5.5
OPENAI_STORYBOARD_TIMEOUT_SECONDS=45
OPENAI_IMAGE_ANALYSIS_MODEL=gpt-5.5
OPENAI_IMAGE_ANALYSIS_DETAIL=original
OPENAI_IMAGE_ANALYSIS_TIMEOUT_SECONDS=60

# MinIO configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_PORT=9002
MINIO_CONSOLE_PORT=9001

# Google OAuth configuration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8001/api/v1/auth/google/callback

# Password reset and verification code configuration
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
VERIFICATION_CODE_LENGTH=6
VERIFICATION_CODE_EXPIRE_SECONDS=300
VERIFICATION_CODE_COOLDOWN_SECONDS=60

# Celery Flower monitoring
FLOWER_USER=admin
FLOWER_PASSWORD=changeme
FLOWER_PORT=5555
